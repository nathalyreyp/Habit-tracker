{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "moduleDetection": "force",
    "noEmit": false,
    "jsx": "react-jsx",
    "strict": false,
    "allowJs": true
  },
  "include": ["src"]
}